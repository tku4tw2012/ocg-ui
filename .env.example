# OCGarden API environment
# Copy to .env.local and fill in values for live API access.
# When any variable is missing, text-intake falls back to mock/console behavior.
# This is intentional — mock mode is the safe default, not a failure state.

# ── Azure-discoverable (can be read from Azure CLI after az login) ──

# Base URL for the OCGarden backend API (no trailing slash)
# Discoverable: az functionapp show --name func-ocg2026-intake-04vmt --resource-group RG_OCG2026 --query properties.defaultHostName
# e.g. https://func-ocg2026-intake-04vmt.azurewebsites.net
VITE_API_BASE_URL=

# ── Backend-provided runtime secrets (NOT Azure-discoverable) ──
# These come from the backend auth setup / app contract.
# They cannot be obtained from Azure CLI or Azure resource inspection.
# Store as Codespaces secrets or in .env.local (gitignored via *.local).
# When absent, the app runs in mock mode — this is expected behavior.

# Device token issued by the backend for authenticated capture POSTs
VITE_OCG_DEVICE_TOKEN=

# Device identifier sent as x-ocg-device-id header
VITE_OCG_DEVICE_ID=
